generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id             String   @id @default(cuid())
  employeeCode   String   @unique
  firstName      String
  lastName       String
  email          String   @unique
  department     String
  jobTitle       String
  country        String
  currency       String
  baseSalary     Decimal
  employmentType String
  hireDate       DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([country])
  @@index([department])
  @@index([jobTitle])
  @@index([baseSalary])
  @@index([lastName, firstName])
}
