{
  "name": "salary-management",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "yarn workspace salary-management-backend dev",
    "dev:frontend": "yarn workspace frontend dev",
    "dev": "concurrently \"yarn dev:backend\" \"yarn dev:frontend\"",
    "test": "yarn workspace salary-management-backend test && yarn workspace frontend test",
    "db:seed": "yarn workspace salary-management-backend db:seed",
    "db:migrate": "yarn workspace salary-management-backend db:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
